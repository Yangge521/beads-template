# Agnes AI API 配置
# 在 https://agnes-ai.com 平台生成 API Key
# 复制此文件为 .env.local 并填入真实 key
VITE_AGNES_API_KEY=your_api_key_here

# 可选：自定义 API 端点（默认 https://apihub.agnes-ai.com/v1/chat/completions）
# VITE_AGNES_API_ENDPOINT=https://apihub.agnes-ai.com/v1/chat/completions

# 可选：自定义模型名（默认 agnes-2.0-flash）
# VITE_AGNES_MODEL=agnes-2.0-flash
